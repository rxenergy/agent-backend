{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "information_need_v1",
  "description": "Node 3 information-need instantiation structured output. required_slots = 답을 방어하려면 근거로 있어야 할 정보 조각(모델이 질의별로 인스턴스화). sub_questions = 다중 독립 물음 분해. version_constraint = 발효/개정 기준일(YYYY-MM-DD) 또는 null.",
  "type": "object",
  "additionalProperties": false,
  "required": ["required_slots"],
  "properties": {
    "required_slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "required": {"type": "boolean"}
        }
      }
    },
    "sub_questions": {"type": "array", "items": {"type": "string"}},
    "version_constraint": {"type": ["string", "null"]},
    "multi_intent": {"type": "boolean"}
  }
}
