{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "classifier_output_v1",
  "description": "Node 1 LLM classifier structured output. Object/Depth = retrieval coordinate; intent = answer-content facet (taxonomy plan §5); scope_tier = handling tier (taxonomy plan §4).",
  "type": "object",
  "additionalProperties": false,
  "required": ["object", "depth", "intent", "scope_tier", "object_confidence", "depth_confidence"],
  "properties": {
    "object": {"type": "string", "enum": ["O1", "O2", "O3", "O4"]},
    "depth": {"type": "string", "enum": ["D1", "D2", "D3"]},
    "intent": {
      "type": "string",
      "enum": ["definition", "feature", "causal", "procedural", "comparison", "compliance", "permissibility", "verification", "status_change", "advisory", "meta", "exploratory", "unknown"]
    },
    "scope_tier": {"type": "string", "enum": ["T1", "T2", "T3", "T4"]},
    "object_confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "depth_confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0}
  }
}
