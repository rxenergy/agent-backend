# AWS MVP profile — frontend-only deployment.
#
# 백엔드(agent-api / vLLM / Postgres / OpenSearch / MinIO …) 는 온프레미스 GPU
# 서버에 그대로 남는다. EC2 단일 인스턴스에는 OpenWebUI 컨테이너 + Caddy
# (TLS 리버스 프록시) + tailscaled 만 떠 있고, Tailscale MagicDNS 로
# `http://onprem-agent:8000/v1` 의 백엔드를 호출한다.
#
# Usage on EC2:
#   docker compose \
#     --env-file ../env/aws-mvp.env \
#     --env-file ../env/aws-mvp.secret.env \
#     -f compose.aws-mvp.yml up -d
#
# 시크릿(*.secret.env) 은 EC2 user-data 가 SSM Parameter Store 에서 가져와
# /etc/agent-frontend/aws-mvp.secret.env 로 기록한 뒤 마운트한다.
# 이미지에 절대 baked-in 금지.

APP_PROFILE=aws-mvp
ENVIRONMENT=production

# ─────────────────────────────────────────────────────────────
# OpenWebUI 동작
# ─────────────────────────────────────────────────────────────
# 사용자-대화 이력 DB 는 SQLite (EBS 볼륨에 영속화).
# DATABASE_URL 은 **아예 정의하지 않는다**. 빈 문자열로 두면 OpenWebUI 가
# 빈 값을 URL 로 파싱하려다 죽는다 (peewee Unrecognized scheme: "").
# unset 일 때만 OpenWebUI 가 sqlite:///${DATA_DIR}/webui.db 를 default 로 사용.
DATA_DIR=/app/backend/data

# Caddy 가 TLS 종단 → open-webui 는 HTTPS 인지 필수
WEBUI_URL=https://dev-agent.rx.energy
WEBUI_SESSION_COOKIE_SECURE=true
WEBUI_SESSION_COOKIE_SAME_SITE=lax
CORS_ALLOW_ORIGIN=https://dev-agent.rx.energy
# Caddy 단일 hop 만 신뢰
FORWARDED_ALLOW_IPS=127.0.0.1

# 백엔드 2개를 *공존* 노출(세미콜론 구분, OPENAI_API_KEYS 와 index 로 짝지음):
#   [0] http://onprem-agent:8000/v1  — 온프레 agent-api(SMR 에이전트). `onprem-agent`
#       는 Tailscale MagicDNS 호스트네임, tailnet 내 :8000 으로 도달.
#   [1] http://litellm:4000/v1       — litellm 사이드카(raw Bedrock Claude passthrough).
# 짝 키(OPENAI_API_KEYS)는 secret.env 에서 user-data 가 합성해 주입한다.
OPENAI_API_BASE_URLS=http://onprem-agent:8000/v1;http://litellm:4000/v1

# ─────────────────────────────────────────────────────────────
# LiteLLM 사이드카 (Bedrock 변환 프록시)
# ─────────────────────────────────────────────────────────────
# Bedrock region — config.yaml 의 inference-profile 이 ACTIVE 한 region.
AWS_REGION=ap-northeast-2
# litellm 컨테이너 이미지 태그(berriai/litellm).
LITELLM_VERSION=main-stable
# t3.small(2GB) OOM 방지용 litellm 메모리 상한. 초과 시 컨테이너만 OOMKill→restart
# (호스트 전체 행 방지). open-webui/caddy 몫을 남기는 값 — 인스턴스 승격 시 상향 가능.
LITELLM_MEM_LIMIT=768m

# 노출 포트 (Caddy 가 :80/:443 점유, open-webui 는 호스트 미노출)
OPEN_WEBUI_VERSION=v0.9.5
OPEN_WEBUI_NAME=RX AI Agent v.1.0

# Caddy
CADDY_VERSION=2.8
CADDY_DOMAIN=dev-agent.rx.energy
CADDY_ACME_EMAIL=dylee@rx.energy

# 이미지 태그 — CI/CD 가 빌드 시 SHA 로 override
FRONTEND_IMAGE=agent-saas/frontend:aws-mvp
