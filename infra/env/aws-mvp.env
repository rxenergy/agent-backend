# AWS MVP profile — frontend-only deployment.
#
# 백엔드(agent-api / vLLM / Postgres / OpenSearch / MinIO …) 는 온프레미스 GPU
# 서버에 그대로 남는다. EC2 단일 인스턴스에는 OpenWebUI + Caddy(TLS 리버스 프록시)
# + litellm(Bedrock 프록시) + searxng(웹검색) + tailscaled 만 떠 있고, MagicDNS 로
# `http://onprem-agent:8000/v1` 의 백엔드를 호출한다.
#
# Usage on EC2:
#   docker compose \
#     --env-file ../env/aws-mvp.env \
#     --env-file ../env/aws-mvp.secret.env \
#     -f compose.aws-mvp.yml up -d
#
# 시크릿(*.secret.env) 은 EC2 user-data 가 SSM Parameter Store 에서 가져와
# /etc/agent-frontend/aws-mvp.secret.env 로 기록한 뒤 마운트한다.
# 이미지에 절대 baked-in 금지.

APP_PROFILE=aws-mvp
ENVIRONMENT=production

# ─────────────────────────────────────────────────────────────
# OpenWebUI 동작
# ─────────────────────────────────────────────────────────────
# 사용자-대화 이력 DB 는 SQLite (EBS 볼륨에 영속화).
# DATABASE_URL 은 **아예 정의하지 않는다**. 빈 문자열로 두면 OpenWebUI 가
# 빈 값을 URL 로 파싱하려다 죽는다 (peewee Unrecognized scheme: "").
# unset 일 때만 OpenWebUI 가 sqlite:///${DATA_DIR}/webui.db 를 default 로 사용.
DATA_DIR=/app/backend/data

# 보조 task(title/tags/follow-up/autocomplete) 생성 비활성화.
# OpenWebUI 는 답변 완료 후 같은 /v1/chat/completions 로 대화 전문을 다시 쏘아
# 제목·태그 등을 생성한다. task model 이 미지정이면 그 요청이 onprem agent 의
# 풀 16-node workflow 로 흘러들어 Phoenix 에 동일 질의가 한 번 더 집계된다
# (백엔드는 <chat_history> scaffolding 을 마지막 사용자 발화로 환원하므로 1차와
# 동일 질의가 됨). MVP 에선 제목 자동생성이 불필요하므로 task 자체를 끈다.
ENABLE_TITLE_GENERATION=false
ENABLE_TAGS_GENERATION=false
ENABLE_AUTOCOMPLETE_GENERATION=false
ENABLE_FOLLOW_UP_GENERATION=false

# Caddy 가 TLS 종단 → open-webui 는 HTTPS 인지 필수
WEBUI_URL=https://dev-agent.rx.energy
WEBUI_SESSION_COOKIE_SECURE=true
WEBUI_SESSION_COOKIE_SAME_SITE=lax
CORS_ALLOW_ORIGIN=https://dev-agent.rx.energy
# Caddy 단일 hop 만 신뢰
FORWARDED_ALLOW_IPS=127.0.0.1

# 백엔드 2개를 *공존* 노출(세미콜론 구분, OPENAI_API_KEYS 와 index 로 짝지음):
#   [0] http://onprem-agent:8000/v1  — 온프레 agent-api(SMR 에이전트). `onprem-agent`
#       는 Tailscale MagicDNS 호스트네임, tailnet 내 :8000 으로 도달.
#   [1] http://litellm:4000/v1       — litellm 사이드카(raw Bedrock Claude passthrough).
# 짝 키(OPENAI_API_KEYS)는 secret.env 에서 user-data 가 합성해 주입한다.
OPENAI_API_BASE_URLS=http://onprem-agent:8000/v1;http://litellm:4000/v1

# 새 채팅 기본 선택 모델 — 콤마(`,`) 구분 다중값을 넣으면 새 채팅이 멀티모델
# 비교(2개 동시 선택) 상태로 열린다. 두 백엔드에서 하나씩 시드한다:
#   [0] composer_pipelined_designer@gemma-4-26b — 온프레 agent-api 설계자 페르소나
#       (`<variant>@<llm>` 전체값; onprem llm id=gemma-4-26b=DEFAULT_LLM).
#   [1] claude-opus-4-8                          — litellm/Bedrock passthrough(opus).
# ⚠ 이건 *기본 선택*일 뿐 잠금이 아니다 — 사용자가 드롭다운에서 1개로 줄이거나
#   다른 모델로 바꿀 수 있다(v0.9.5 엔 선택 강제 env 없음).
# ⚠ 멀티모델 동시 호출 시 litellm(Bedrock) 경로는 strip_history 로 완전 single-turn
#   이 된다(멀티턴 맥락·재현성은 온프레 agent-api Connection 에서만 보장).
OPEN_WEBUI_DEFAULT_MODELS=composer_pipelined_designer@gemma-4-26b,claude-opus-4-8

# ─────────────────────────────────────────────────────────────
# Web Search (SearXNG 사이드카)
# ─────────────────────────────────────────────────────────────
# OpenWebUI 내장 웹검색. SearXNG(메타검색)로 질의→본문 스크랩→RAG 컨텍스트 주입.
# 두 백엔드(온프레/Bedrock) 공통 적용. 사용자가 채팅 "+" 메뉴에서 Web Search 를
# 켠 turn 에만 실행된다. API key 불필요(SSM 시크릿 0개), Valkey 불필요(limiter OFF).
#
# ⚠ onprem(air-gapped) 프로파일에는 넣지 않는다 — 외부 검색사로 질의가 송신된다.
ENABLE_WEB_SEARCH=true
WEB_SEARCH_ENGINE=searxng
# <query> 는 OpenWebUI 가 치환하는 리터럴 플레이스홀더. searxng 는 compose 네트워크
# 내부 호스트명(호스트 미노출).
SEARXNG_QUERY_URL=http://searxng:8080/search?q=<query>
# 결과 상위 N 건을 컨텍스트로 사용.
WEB_SEARCH_RESULT_COUNT=4
# 결과 페이지 본문 스크랩 동시성. t3.large 여력 반영. self-host SearXNG 라
# 레이트리밋 무관(외부 API key 엔진이면 1 로 낮춰야 함).
WEB_SEARCH_CONCURRENT_REQUESTS=4
# searxng 컨테이너 이미지 태그 / 메모리 상한.
SEARXNG_VERSION=latest
SEARXNG_MEM_LIMIT=512m

# ─────────────────────────────────────────────────────────────
# LiteLLM 사이드카 (Bedrock 변환 프록시)
# ─────────────────────────────────────────────────────────────
# Bedrock region — config.yaml 의 inference-profile 이 ACTIVE 한 region.
AWS_REGION=ap-northeast-2
# litellm 컨테이너 이미지 태그(berriai/litellm).
LITELLM_VERSION=main-stable
# t3.small(2GB) OOM 방지용 litellm 메모리 상한. 초과 시 컨테이너만 OOMKill→restart
# (호스트 전체 행 방지). open-webui/caddy 몫을 남기는 값 — 인스턴스 승격 시 상향 가능.
LITELLM_MEM_LIMIT=768m

# 노출 포트 (Caddy 가 :80/:443 점유, open-webui 는 호스트 미노출)
OPEN_WEBUI_VERSION=v0.9.5
OPEN_WEBUI_NAME=RX AI Agent v.1.0

# Caddy
CADDY_VERSION=2.8
CADDY_DOMAIN=dev-agent.rx.energy
CADDY_ACME_EMAIL=dylee@rx.energy

# 이미지 태그 — CI/CD 가 빌드 시 SHA 로 override
FRONTEND_IMAGE=agent-saas/frontend:aws-mvp
