# On-premise profile (v2) — second 노드를 AWS Bedrock Haiku 로 두는 변형.
#
# 기본 onprem.env 와 동일하되, 서브 vLLM 노드(2번째 DGX Spark)를 연결하지 않은 경우
# relevance(retrieval.verify_slot)·multihop(retrieval.follow_up)을 **AWS Bedrock Claude
# Haiku** 로 돌린다. main(생성·앞단)은 여전히 내부망 vLLM(gemma-4-26b).
#
# ⚠ 완전 air-gapped 가 아니다 — SECONDARY_LLM 이 bedrock 이므로 backend 가 AWS
#   bedrock-runtime 으로 아웃바운드한다. 폐쇄망 정책이 외부 SaaS 를 금지하면 이 변형 대신
#   onprem.env(서브 vLLM) 또는 단일노드(SECONDARY_LLM 미설정)를 쓴다. 검증/외부참조 청크
#   본문이 Bedrock 으로 송신됨에 유의(데이터 거버넌스 검토 필요).
#
# 사용: APP_PROFILE 오버레이로 이 파일을 onprem.env 대신 로드하거나, onprem.env 위에
#   덮어쓴다(LLM_POOL/SECONDARY_LLM 만 다르고 나머지는 동일).
APP_PROFILE=onprem
ENVIRONMENT=production
LOG_LEVEL=INFO

AGENT_VARIANTS_ENABLED=["composer_pipelined","composer_pipelined_reviewer","composer_pipelined_designer","composer_pipelined_operator"]
DEFAULT_VARIANT=composer_pipelined

# OpenTelemetry → collector → Phoenix + Tempo
OTEL_ENABLED=true
OTEL_SERVICE_NAME=smr-agent-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=http://phoenix:6006
# Phoenix UI/스토리지 튜닝 (compose.yml phoenix 서비스가 참조).
# 백엔드는 Postgres(공유 인스턴스의 phoenix DB) — SQLite 병목 제거.
PHOENIX_VERSION=version-17.8.1
PHOENIX_RETENTION_DAYS=30
PHOENIX_ALLOW_EXTERNAL_RESOURCES=false

# Prompt / tool registries (mounted into image)
PROMPT_SOURCE=local
PROMPT_LABEL=mvp
PROMPT_LOCAL_DIR=/app/prompts

TOOL_REGISTRY_PATH=/app/tools/registry.yaml
TOOL_TRACE_ENABLED=true
TOOL_TIMEOUT_DEFAULT_MS=3000
TOOL_RETRY_DEFAULT=0

# Classifier / verification
CLASSIFIER_BACKEND=llm
CLASSIFICATION_THRESHOLD=0.35
CLASSIFIER_ESCALATE_BELOW=0.35

VERIFICATION_CITATION_THRESHOLD=0.9
VERIFICATION_FAITHFULNESS_THRESHOLD=0.80
VERIFICATION_RETRY_ON_FAIL=true

CLAIM_VERIFICATION_ENABLED=false

RETRIEVER_TOP_K=5
RETRIEVER_MIN_TOKEN_COUNT=50

SPEC_DRIVEN_MAX_QUERIES=10
SPEC_DRIVEN_MAX_CONTEXT_CHUNKS=10
SPEC_DRIVEN_CONTEXT_TOKEN_BUDGET=200000

ACTIVE_CELLS_MODE=all

MULTI_TURN_SUMMARY_ENABLED=true
MULTI_TURN_KEEP_TURNS=5

# AWS Bedrock region — Haiku inference-profile 이 ACTIVE 한 region. region 에서 조회한
# 실제 프로파일 ID 를 model 에 넣는다(local.env 주석의 list-inference-profiles 참고).
AWS_REGION=ap-northeast-2

# LLM pool — main 은 내부망 vLLM(gemma-4-26b), second 는 AWS Bedrock Haiku.
# served-model-name 은 compose 의 VLLM_SERVED_MODEL_NAME 과 일치해야 한다.
# claude-haiku-4-5 — provider=bedrock(SECONDARY_LLM 가 이 id 를 가리킨다). endpoint 는
#   region 에서 유도(미사용). api_key_env 는 `bedrock-api-key-...` bearer token 환경변수명
#   (미설정 시 SigV4 IAM 자격으로 폴백). model 은 region 에서 ACTIVE 한 inference-profile
#   ID 여야 한다(추측 금지 — region 조회, local.env 주석 참고).
LLM_POOL='[
    {"id":"gemma-4-26b","provider":"openai_compat","endpoint":"http://vllm:8000/v1","model":"gemma-4-26b-a4b-it"},
    {"id":"claude-haiku-4-5","provider":"bedrock","model":"global.anthropic.claude-haiku-4-5-20251001-v1:0","api_key_env":"AWS_BEARER_TOKEN_BEDROCK"},
    {"id":"claude-opus-4-8","provider":"bedrock","model":"global.anthropic.claude-opus-4-8","api_key_env":"AWS_BEARER_TOKEN_BEDROCK"}
]'
DEFAULT_LLM=gemma-4-26b
UTILITY_LLM=gemma-4-26b
# worker 노드 — relevance(retrieval.verify_slot)·multihop(retrieval.follow_up)을 *둘 다*
# AWS Bedrock Haiku 로 돈다(서브 vLLM 미연결 시 대안). main(gemma-4-26b)은 생성·앞단
# (N0/N1/N2) 전담 → 검색-검증 fan-out 이 생성 디코딩 큐와 경쟁하지 않아 검증↔생성이 물리
# 병렬(Bedrock 은 별개 엔드포인트라 vLLM 큐와 분리). Bedrock 은 guided_json 대신 프롬프트
# JSON 지시로 구조화 출력(profiles.py _STRUCTURED_PROVIDERS). 빈 값이면 default_llm 폴백
# (단일노드 — verify/follow_up 이 main vLLM 에서 돌아 생성과 경쟁).
# ⚠ LLM_POOL 의 id 와 *정확히* 일치해야 한다 — 불일치 시 boot fail-fast(profiles.py).
SECONDARY_LLM=claude-haiku-4-5
SPEC_DRIVEN_V2_VERIFY_ENABLED=true
# 동시 슬롯 검증 캡. Bedrock 은 vLLM continuous batching 이 아니라 독립 API 호출이므로
# 동시 호출이 Bedrock 계정 TPS/RPM 쿼터에 묶인다 — vLLM(64) 대비 보수적으로 둔다(쓰로틀
# 시 LLM_MAX_ATTEMPTS 재시도가 흡수하나, 캐스케이드 방지로 낮춤). 청크별 전역 캡은 별도
# 변수 없이 SPEC_DRIVEN_MAX_QUERIES 재사용(profiles.py).
SPEC_DRIVEN_V2_VERIFY_CONCURRENCY=6
# Bedrock 왕복은 사내망 vLLM 보다 지연이 크고 쓰로틀 가능 — timeout·재시도 여유.
LLM_TIMEOUT_S=60
LLM_MAX_ATTEMPTS=3

# ── Retrieval — OpenSearch 3.6 단일 노드 (onprem.env 와 동일) ──
RETRIEVER_BACKEND=opensearch
OPENSEARCH_ENDPOINT=http://opensearch:9200
OPENSEARCH_INDEX=nrc-all-v1
OPENSEARCH_SEARCH_PIPELINE=nrc-hybrid-search
OPENSEARCH_DENSE_FIELD=dense_e5
OPENSEARCH_SPARSE_FIELD=sparse_fermi
OPENSEARCH_TEXT_FIELD=text
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=false
RETRIEVER_K_DENSE=50

# Embedding (onprem.env 와 동일 — 호스트 ./models 평면 디렉토리)
EMBEDDING_E5_MODEL=/app/models/intfloat/multilingual-e5-large
EMBEDDING_FERMI_MODEL=/app/models/atomic-canyon/fermi-1024
EMBEDDING_DEVICE=cpu
EMBEDDING_E5_MAX_SEQ_LEN=512
EMBEDDING_FERMI_MAX_SEQ_LEN=1024
EMBEDDING_FERMI_TOP_N=200

# State DB / Memory
STATE_DB_URL=postgresql://agent:agent@postgres:5432/agent_state
MEMORY_ENABLED=true
MEMORY_STORE=postgres
MEMORY_VECTOR_BACKEND=pgvector
MEMORY_REVIEW_REQUIRED=true
MEMORY_APPROVED_ONLY=true
MEMORY_SESSION_TTL_DAYS=90
MEMORY_STALENESS_CHECK_ENABLED=true

# Artifact / event sink — onprem 은 MinIO
EVENT_SINK=minio
EVENT_BUCKET=smr-agent-events
EVENT_PREFIX=onprem
EVENT_FILESYSTEM_ROOT=/var/lib/agent/events
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Capture modes
TRACE_CONTENT_MODE=full
CONTEXT_CAPTURE_MODE=full

# Compose
BACKEND_TAG=onprem

# OpenWebUI
OPEN_WEBUI_VERSION=main
OPEN_WEBUI_PORT=3100
OPEN_WEBUI_AUTH=true
OPEN_WEBUI_NAME=SMR Agent (On-Prem / Bedrock sub)
OPEN_WEBUI_SECRET_KEY=change-me-onprem
OPEN_WEBUI_AGENT_KEY=dummy

# follow-up 참조 추출 (통합 메타데이터)
DOCUMENTS_METADATA_CSV=/app/data/ref/metadata_unified.csv
DOCUMENTS_METADATA_CACHE=/app/data/ref/_ref_catalog.json
# Bedrock 동시성 캡 — vLLM continuous batching 이 아니라 독립 API 호출이라 Bedrock 쿼터에
# 묶인다. vLLM(8) 대비 보수적으로(쓰로틀 시 per-call 재시도가 흡수). 쿼터 여유 보면 상향.
DOCUMENTS_REF_MAX_CONCURRENCY=4
DOCUMENTS_REF_VLLM_TIMEOUT_S=30

# vLLM — main 노드(생성·앞단)만. second 는 Bedrock 이라 서브 vLLM 불필요.
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_MODEL_DIR=/workspace/models/gemma4-awq
VLLM_SERVED_MODEL_NAME=gemma-4-26b-a4b-it
VLLM_MAX_MODEL_LEN=131072
VLLM_MAX_NUM_SEQS=64
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_GPU_MEMORY_UTILIZATION=0.70
VLLM_KV_CACHE_DTYPE=fp8

# Phoenix Prompt Playground → 내부망 vLLM 직결 (onprem 전용).
PHOENIX_OPENAI_BASE_URL=http://vllm:8000/v1
PHOENIX_OPENAI_API_KEY=dummy
