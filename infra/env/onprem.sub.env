# 서브 노드 vLLM 전용 환경값 (onprem 2번째 노드).
#
# 메인 노드의 VLLM_*(infra/env/onprem.env)와 **완전히 독립**이다. 지금은 메인과 동일한
# gemma-4-26b 를 띄우지만, 이 파일과 compose.onprem.sub.yml 은 메인과 분리돼 있어 아래 값만
# 바꾸면 서브에 "다른 모델"을 독립적으로 올릴 수 있다(메인 설정/컨테이너에는 전혀 영향 없음).
#
# 사용 (메인에서 `make up-onprem-sub` 가 Docker Context 로 서브 원격 데몬에 실행):
#   docker -c onprem-sub compose \
#     -f infra/compose/compose.onprem.sub.yml --env-file infra/env/onprem.sub.env up -d

VLLM_IMAGE=vllm/vllm-openai:latest

# 서브 노드의 모델 디렉토리(호스트 절대경로). Docker Context(ssh://)로 원격 데몬에서
# 실행되므로 이 경로는 *서브 노드* 파일시스템 기준이다. 컨테이너 내부에는 /workspace/models
# 로 마운트된다(VLLM_MODEL_DIR 는 그 컨테이너 내부 경로).
VLLM_MODELS_HOST_DIR=/home/rx/rx/agent-backend/models

# --- 모델 선택 (다른 모델로 바꾸려면 여기 값들 수정) ---------------------------
# 1) 모델 가중치를 서브 노드의 VLLM_MODELS_HOST_DIR/<폴더> 에 둔다.
# 2) 아래 값을 그 모델에 맞게 바꾼다(VLLM_MODEL_DIR 는 컨테이너 내부 /workspace/models 기준).
VLLM_MODEL_DIR=/workspace/models/gemma4-awq
VLLM_SERVED_MODEL_NAME=gemma-4-26b-a4b-it
VLLM_QUANTIZATION=compressed-tensors
VLLM_LOAD_FORMAT=safetensors
# 비양자화 모델이면 VLLM_QUANTIZATION 을 비운다(빈 값). 단 compose 의 --quantization 라인이
# 빈 인자를 허용하지 않으면 compose.onprem.sub.yml 에서 해당 라인을 주석 처리한다.
# ------------------------------------------------------------------------------

# 컨텍스트는 모델 상한(gemma-4: max_position_embeddings=262144, 256K)까지 상향
# (test docker-compose.sub.yml 의 --max-model-len 기본값 262144 기준).
# ⚠ KV cache 부족 시 vLLM 이 가능한 최대치를 에러로 알려준다 → 아래 값을 그 값으로
#   낮춰 재기동(필요 시 VLLM_GPU_MEMORY_UTILIZATION 상향).
VLLM_MAX_MODEL_LEN=262144
VLLM_KV_CACHE_DTYPE=fp8

# 동시성/배칭 (test 서브 노드 벤치 B설정: verify 동시 30요청 합산 244→739 tok/s, 약 3배).
VLLM_MAX_NUM_SEQS=64
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_GPU_MEMORY_UTILIZATION=0.70
