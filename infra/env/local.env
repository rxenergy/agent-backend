# Local development profile (v2)
APP_PROFILE=local
ENVIRONMENT=development
LOG_LEVEL=INFO

# Agent variant pool. /v1/models 드롭다운에 변종@LLM 조합으로 노출된다.
# agentic_finder_v4 기본(3-Phase Intake→Retrieval→Generation, Finder tool-calling 루프).
# v3.1 hierarchical_corrective 병행 노출(다전략 검색·5신호 게이트·claim 검증·recover).
# react_minimal_v1 — 최소 2-Phase ReAct 베이스라인(분류기·번역·메모리 없음, 모델 추론
# 주도). 클라이언트가 model=react_minimal_v1@gemma-4-26b 로 선택한다(기본 변종 아님).
# react_echo_v1 — react_minimal 의 도구-최소(echo) 변형: 검색 루프 도구를 retrieval.search
# + submit_response 로 좁히고 키워드-보존형 프롬프트로 검색 질의 작성을 모델 추론에 맡긴다.
AGENT_VARIANTS_ENABLED=["spec_driven_v1", "composer"]
DEFAULT_VARIANT="spec_driven_v1"

# OpenTelemetry → collector → Phoenix + Tempo
OTEL_ENABLED=true
OTEL_SERVICE_NAME=smr-agent-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=http://phoenix:6006

# Prompt registry (mounted at /app/prompts)
PROMPT_SOURCE=local
PROMPT_LABEL=mvp
PROMPT_LOCAL_DIR=/app/prompts

# Tool registry (mounted at /app/tools)
TOOL_REGISTRY_PATH=/app/tools/registry.yaml
TOOL_TRACE_ENABLED=true
TOOL_TIMEOUT_DEFAULT_MS=3000
TOOL_RETRY_DEFAULT=0

# Classifier (Node 1, 기획 doc §Node1)
CLASSIFIER_BACKEND=hybrid
CLASSIFICATION_THRESHOLD=0.35
CLASSIFIER_ESCALATE_BELOW=0.35

# Verification thresholds (Node 4, 기획 doc §Node4)
# faithfulness 0.80 = 휴리스틱(0.6+0.1·n) 기준 청크 2개에서 통과.
# 진짜 faithfulness 평가(Ragas) 도입 시 0.85로 환원하고 휴리스틱 자체를 폐기 — Phase W6.
VERIFICATION_CITATION_THRESHOLD=0.9
VERIFICATION_FAITHFULNESS_THRESHOLD=0.80
VERIFICATION_RETRY_ON_FAIL=true

# Retrieval breadth — operating point. k=5 는 base pipeline(OPENSEARCH_SEARCH_PIPELINE
# =nrc-hybrid-search)을 사용한다. k5 전용 가중치 pipeline 은 클러스터 미등록이라
# profiles.py 의 operating-point 맵에서 제외됨(등록 시 재추가).
RETRIEVER_TOP_K=5

# Active cell policy (기획 doc §3 / §7)
# all          — 16개 셀 모두 답변 시도, verification이 품질 게이트
# top_priority — §3 Top Priority 5셀(O1×D2, O4×D2, O3×D2, O3×D3, O2×D4)만 활성,
#                나머지는 "현재 단계 답변 제한적" 안내로 거절
ACTIVE_CELLS_MODE=all

# Multi-turn summary (Node 5, 기획 doc §Multi-Turn Context Handling)
MULTI_TURN_SUMMARY_ENABLED=true
MULTI_TURN_KEEP_TURNS=5

# LLM pool — `fake-echo` is always present automatically. Add real backends as a
# JSON list. The pool ids appear in /v1/models as `<variant>@<id>`. Secrets live
# in env vars referenced by `api_key_env` (keep them in `local.secret.env`).
#
# Three providers:
#   - openai_compat — vLLM/OpenAI/LM Studio/Ollama (/v1/chat/completions). `Authorization: Bearer`.
#   - anthropic     — Anthropic /v1/messages. `x-api-key` from `api_key_env`.
#   - bedrock       — Amazon Bedrock. Same Anthropic Messages wire format. `endpoint`
#       unused — `region` (here) or `AWS_REGION` picks the endpoint. `model` is a Bedrock
#       model id / inference-profile id/ARN (e.g. `anthropic.claude-opus-4-8`,
#       `apac.anthropic.claude-sonnet-4-6`). Two auth modes:
#         · 임시 API 키(bearer): api_key_env 에 `bedrock-api-key-...` 토큰을 담은 env 이름을
#           지정(미지정 시 AWS_BEARER_TOKEN_BEDROCK 자동 사용). IAM access key 불필요.
#         · SigV4(폴백): bearer 토큰 없으면 표준 AWS 체인(env AWS_ACCESS_KEY_ID/SECRET
#           [/SESSION_TOKEN], 공유 프로파일, IAM role)으로 서명. aws-mvp EC2 IAM role 에 맞음.
#
# Examples (uncomment + edit):
#   LLM_POOL='[
#     {"id":"gemma-2-9b","provider":"openai_compat","endpoint":"http://vllm:8000/v1","model":"google/gemma-2-9b-it"},
#     {"id":"claude-haiku-4-5","provider":"anthropic","endpoint":"https://api.anthropic.com/v1","model":"claude-haiku-4-5","api_key_env":"ANTHROPIC_API_KEY"},
#     {"id":"claude-opus-bedrock-key","provider":"bedrock","model":"anthropic.claude-opus-4-8","region":"us-east-1","api_key_env":"AWS_BEARER_TOKEN_BEDROCK"},
#     {"id":"claude-opus-bedrock-iam","provider":"bedrock","model":"anthropic.claude-opus-4-8","region":"us-east-1"}
#   ]'
# local 은 Bedrock 기준. provider=bedrock, region 미지정 시 aws_region(ap-northeast-2).
# model 은 *해당 region 에서 ACTIVE 한 inference-profile ID* 여야 한다. 신형 Claude 는
# on-demand base ID(`anthropic.claude-*`) 직접 호출이 막혀 있어 `global.` 프로파일을
# 쓴다. ID 형식은 모델마다 달라 추측하지 말고 region 에서 조회한다:
#   aws bedrock list-inference-profiles --region ap-northeast-2 \
#     --query "inferenceProfileSummaries[?contains(inferenceProfileId,'anthropic')].inferenceProfileId"
#   → opus 4.8 / sonnet 4.6 은 suffix 없는 global ID, haiku 4.5 는 날짜+버전 suffix.
LLM_POOL='[
    {"id":"claude-haiku-4-5","provider":"bedrock","model":"global.anthropic.claude-haiku-4-5-20251001-v1:0","api_key_env":"AWS_BEARER_TOKEN_BEDROCK"},
    {"id":"claude-sonnet-4-6","provider":"bedrock","model":"global.anthropic.claude-sonnet-4-6","api_key_env":"AWS_BEARER_TOKEN_BEDROCK"},
    {"id":"claude-opus-4-8","provider":"bedrock","model":"global.anthropic.claude-opus-4-8","api_key_env":"AWS_BEARER_TOKEN_BEDROCK"}
]'
DEFAULT_LLM=claude-sonnet-4-6
UTILITY_LLM=claude-haiku-4-5
LLM_TIMEOUT_S=30
LLM_MAX_ATTEMPTS=2

# ── Retrieval (Agent ↔ OpenSearch interface) ──
# backend 선택: opensearch | local(fake).
# 실 와이어링은 backend/app/config/profiles.py 의 build_runtime() 분기에서 결정한다.
# 단위 테스트 / 외부 의존 없는 부팅은 RETRIEVER_BACKEND=local 로 명시 override 한다.
RETRIEVER_BACKEND=opensearch
OPENSEARCH_ENDPOINT=http://opensearch:9200
OPENSEARCH_INDEX=nrc-all-v1
# hybrid 폴백 pipeline. RETRIEVER_TOP_K 가 벤치마크 operating point 면 자동
# 오버라이드된다: 10→nrc-hybrid-search-k10([0.4,0.2,0.4]). k=5(및 그 외)는 이 값을
# 사용 — k5 전용 pipeline 은 클러스터 미등록이라 맵에서 제외됨(profiles.py).
OPENSEARCH_SEARCH_PIPELINE=nrc-hybrid-search
OPENSEARCH_DENSE_FIELD=dense_e5
OPENSEARCH_SPARSE_FIELD=sparse_fermi
OPENSEARCH_TEXT_FIELD=text
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=false
RETRIEVER_K_DENSE=50

# Embedding models for hybrid retrieval (loaded in backend when RETRIEVER_BACKEND=opensearch)
EMBEDDING_E5_MODEL=intfloat/multilingual-e5-large
EMBEDDING_FERMI_MODEL=atomic-canyon/fermi-1024
EMBEDDING_DEVICE=cpu
EMBEDDING_E5_MAX_SEQ_LEN=512
EMBEDDING_FERMI_MAX_SEQ_LEN=1024
EMBEDDING_FERMI_TOP_N=200

# State DB / Memory
STATE_DB_URL=postgresql://agent:agent@postgres:5432/agent_state
MEMORY_ENABLED=true
MEMORY_STORE=postgres
MEMORY_VECTOR_BACKEND=pgvector
MEMORY_REVIEW_REQUIRED=true
MEMORY_APPROVED_ONLY=true
MEMORY_SESSION_TTL_DAYS=90
MEMORY_STALENESS_CHECK_ENABLED=true

# Artifact / event sink
EVENT_SINK=minio
EVENT_BUCKET=smr-agent-events
EVENT_PREFIX=local
EVENT_FILESYSTEM_ROOT=/var/lib/agent/events
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Capture modes (local allows full snapshot)
TRACE_CONTENT_MODE=full
CONTEXT_CAPTURE_MODE=full

# Compose
BACKEND_TAG=dev

# OpenWebUI (UI shell, persistence on shared Postgres `openwebui` DB)
OPEN_WEBUI_VERSION=main
OPEN_WEBUI_PORT=3100
OPEN_WEBUI_AUTH=true
OPEN_WEBUI_NAME=RX Agent
OPEN_WEBUI_SECRET_KEY=change-me-local
OPEN_WEBUI_AGENT_KEY=dummy
