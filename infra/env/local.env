# Local development profile (v2)
APP_PROFILE=local
ENVIRONMENT=development
LOG_LEVEL=INFO

# Agent variant
AGENT_VARIANT=sequential_tool_routed_v2
EXPOSED_MODEL_ID=agent-search-v1

# OpenTelemetry → collector → Phoenix + Tempo
OTEL_ENABLED=true
OTEL_SERVICE_NAME=smr-agent-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=http://phoenix:6006

# Prompt registry (mounted at /app/prompts)
PROMPT_SOURCE=local
PROMPT_LABEL=mvp
PROMPT_LOCAL_DIR=/app/prompts

# Tool registry (mounted at /app/tools)
TOOL_REGISTRY_PATH=/app/tools/registry.yaml
TOOL_TRACE_ENABLED=true
TOOL_TIMEOUT_DEFAULT_MS=3000
TOOL_RETRY_DEFAULT=0

# Classifier (Node 1, 기획 doc §Node1)
CLASSIFIER_BACKEND=hybrid
CLASSIFICATION_THRESHOLD=0.35
CLASSIFIER_ESCALATE_BELOW=0.35

# Verification thresholds (Node 4, 기획 doc §Node4)
VERIFICATION_CITATION_THRESHOLD=0.9
VERIFICATION_FAITHFULNESS_THRESHOLD=0.85
VERIFICATION_RETRY_ON_FAIL=true

# Multi-turn summary (Node 5, 기획 doc §Multi-Turn Context Handling)
MULTI_TURN_SUMMARY_ENABLED=true
MULTI_TURN_KEEP_TURNS=5

# LLM provider (W1)
# Default is `fake` so `make up-local` boots without external credentials.
# Switch to a real provider by overriding these in `infra/env/local.secret.env`
# (gitignored) and exporting it before `docker compose up`.
#
# Option A — vLLM (OpenAI-compatible, on-prem / local GPU):
#   LLM_PROVIDER=openai_compat
#   LLM_ENDPOINT=http://vllm:8000/v1
#   LLM_MODEL=google/gemma-2-9b-it
#   LLM_API_KEY=               # vLLM usually doesn't require one
#
# Option B — Anthropic Cloud API:
#   LLM_PROVIDER=anthropic
#   LLM_ENDPOINT=https://api.anthropic.com/v1
#   LLM_MODEL=claude-haiku-4-5
#   LLM_API_KEY=sk-ant-...     # keep in local.secret.env
LLM_PROVIDER=fake
LLM_ENDPOINT=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_S=30
LLM_MAX_ATTEMPTS=2

# Retriever backend (W1)
RETRIEVER_BACKEND=local
OPENSEARCH_ENDPOINT=http://opensearch:9200
OPENSEARCH_INDEX=smr-docs
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=false

# State DB / Memory
STATE_DB_URL=postgresql://agent:agent@postgres:5432/agent_state
MEMORY_ENABLED=true
MEMORY_STORE=postgres
MEMORY_VECTOR_BACKEND=pgvector
MEMORY_REVIEW_REQUIRED=true
MEMORY_APPROVED_ONLY=true
MEMORY_SESSION_TTL_DAYS=90
MEMORY_STALENESS_CHECK_ENABLED=true

# Artifact / event sink
EVENT_SINK=minio
EVENT_BUCKET=smr-agent-events
EVENT_PREFIX=local
EVENT_FILESYSTEM_ROOT=/var/lib/agent/events
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Capture modes (local allows full snapshot)
TRACE_CONTENT_MODE=full
CONTEXT_CAPTURE_MODE=full

# Compose
BACKEND_TAG=dev

# OpenWebUI (UI shell, persistence on shared Postgres `openwebui` DB)
OPEN_WEBUI_VERSION=main
OPEN_WEBUI_PORT=3100
OPEN_WEBUI_AUTH=true
OPEN_WEBUI_NAME=SMR Agent
OPEN_WEBUI_SECRET_KEY=change-me-local
OPEN_WEBUI_AGENT_KEY=dummy
