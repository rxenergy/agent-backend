# On-premise profile (v2) — air-gapped VM/bare metal.
# 외부 네트워크 없음. LLM은 호스트 GPU의 vLLM(gemma-4-26b-a4b-it) 단일.
APP_PROFILE=onprem
ENVIRONMENT=production
LOG_LEVEL=INFO

# Agent variant. 기본 agentic_finder_v4 — N0 번역·N2 답변사양·N3 Finder 루프는 모두
# 내부망 utility LLM(vLLM, openai_compat → generate_with_tools)을 사용한다. v3.1
# hierarchical_corrective 의 claim 분해·함의 검증도 동일 내부 LLM — onprem air-gapped
# 정책과 호환(외부 SaaS 미사용).
# composer_pipelined + 페르소나 3종(composer_persona_framework.design.v1) 활성화 —
# OpenWebUI /v1/models 가 이 활성 variant 들을 자동 발견해 드롭다운에 노출한다.
# 활성 리스트에 없으면 container.runners 에 안 들어가 선택 불가(표시 안 됨의 주원인).
AGENT_VARIANTS_ENABLED=["composer_pipelined","composer_pipelined_reviewer","composer_pipelined_designer","composer_pipelined_operator"]
DEFAULT_VARIANT=composer_pipelined

# OpenTelemetry → collector → Phoenix + Tempo
OTEL_ENABLED=true
OTEL_SERVICE_NAME=smr-agent-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# span 속성 값 문자 상한 — 거대 슬롯 프롬프트로 트레이스가 부푸는 것을 앱 단에서 막는다.
# 전체 본문은 context_snapshot+rendered_prompt_hash 로 재현. 0/빈값=무제한(콜렉터 한도만).
OTEL_SPAN_ATTR_MAX_CHARS=65536

PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=http://phoenix:6006
# Phoenix UI/스토리지 튜닝 (compose.yml phoenix 서비스가 참조).
# 백엔드는 Postgres(공유 인스턴스의 phoenix DB) — SQLite 병목 제거.
# SQLite -> Postgres 전환 전 기존 trace 는 scripts/phoenix_backup.sh 로 콜드
# 아카이브한다 (docs/references/phoenix_performance_tuning.md 참조).
PHOENIX_VERSION=version-17.8.1
PHOENIX_RETENTION_DAYS=30
# onprem 은 air-gapped(또는 전환 예정) → 외부 리소스 fetch 차단 (렌더 블록 방지).
PHOENIX_ALLOW_EXTERNAL_RESOURCES=false

# Prompt / tool registries (mounted into image)
PROMPT_SOURCE=local
PROMPT_LABEL=mvp
PROMPT_LOCAL_DIR=/app/prompts

TOOL_REGISTRY_PATH=/app/tools/registry.yaml
TOOL_TRACE_ENABLED=true
TOOL_TIMEOUT_DEFAULT_MS=3000
TOOL_RETRY_DEFAULT=0

# Classifier / verification
CLASSIFIER_BACKEND=llm
CLASSIFICATION_THRESHOLD=0.35
CLASSIFIER_ESCALATE_BELOW=0.35

VERIFICATION_CITATION_THRESHOLD=0.9
VERIFICATION_FAITHFULNESS_THRESHOLD=0.80
VERIFICATION_RETRY_ON_FAIL=true

CLAIM_VERIFICATION_ENABLED=false

# operating point. k=5 → base pipeline(OPENSEARCH_SEARCH_PIPELINE=nrc-hybrid-search)
# 사용. k5 전용 가중치 pipeline 은 클러스터 미등록이라 맵에서 제외됨(profiles.py).
RETRIEVER_TOP_K=5

# 노이즈 floor(Layer 2) — 본문 토큰 < N chunk(목차·헤더·fragment) 제외. spec_driven_v1
# 은 retrieval.scope 도구를 우회하므로 runner 가 이 값을 retrieval.search 에 직접 싣는다
# (v3.1/react 은 corpus_map.chunk_quality 가 우선). opensearch 백엔드 + token_count 적재
# 전제(부재 chunk 는 range 필터에 조용히 누락) — local fake 백엔드에선 전량 누락되니 주의.
RETRIEVER_MIN_TOKEN_COUNT=50

# spec_driven_v1 — N2 슬롯당 멀티쿼리 상한 + N3 병합 후 컨텍스트 chunk 예산(1차 floor
# 정렬 budget). 컨텍스트 윈도 확장 모델(vLLM long-context)에서 더 많은 슬롯·다양 쿼리로
# 근거를 넓게 모은다(per-slot floor 가 required 근거를 먼저 확보 후 score 순으로 채움).
SPEC_DRIVEN_MAX_QUERIES=10
SPEC_DRIVEN_MAX_CONTEXT_CHUNKS=10

# spec_driven_v1 N4 생성 컨텍스트 — 1차 검색 전량 보존 + 2차 검색 score 순 채움을
# 토큰 예산으로 제한. vLLM VLLM_MAX_MODEL_LEN=131072(128K), 생성 max_tokens=8192.
# CONTEXT_CAPTURE_MODE=full 이므로 chunk *전문* + 표 인라인 확장이 컨텍스트로 들어간다
# (snippet 2048자 캡 아님) → chunk 당 부피가 수 배 커진다. 9000(snippet 전제) 으로는
# 전문 1~2개만으로 예산이 차 표 담은 1차 근거가 _assemble_final_chunks 에서 잘리므로
# (first_pass_dropped), 128K 윈도우에 맞춰 200000 으로 상향한다 — 입력 200K + 출력
# 8192 + 프롬프트/시스템 오버헤드가 128K 안에 든다. 추정 휴리스틱(_estimate_chunk_tokens)
# 은 표 치환 *전* 길이라 약간 과소추정하나, 이 큰 헤드룸이 흡수한다.
# 주: SPEC_DRIVEN_MAX_CONTEXT_CHUNKS 는 더 이상 최종 cap 이 아니다 — N3 1차 floor
# 정렬 budget 일 뿐이고, 최종 컨텍스트 크기는 이 토큰 예산이 지배한다.
SPEC_DRIVEN_CONTEXT_TOKEN_BUDGET=200000

ACTIVE_CELLS_MODE=all

MULTI_TURN_SUMMARY_ENABLED=true
MULTI_TURN_KEEP_TURNS=5

# LLM pool — onprem 은 메인 노드 vLLM(gemma-4-26b) 기본. fake-echo 는 항상 자동 포함.
# served-model-name 은 compose 의 VLLM_SERVED_MODEL_NAME 과 일치해야 한다.
#
# gemma-4-26b-sub — 서브 노드(2번째 vLLM)다. agent-api 는 컨테이너 DNS 가 아니라 서브 노드
#   호스트 IP:포트로 닿는다(compose.onprem.sub.yml 이 호스트 8001 로 노출). endpoint 의 IP 는
#   서브 노드 호스트(Makefile SUB_SSH 의 IP)와 반드시 일치시킬 것.
#   ⚠ 백엔드는 풀을 id 기준 단일 조회만 하며 자동 부하분산이 없다(llm_router.py). 서브는
#   클라이언트가 `variant@gemma-4-26b-sub` 로 명시 요청하거나, 추후 특정 역할(UTILITY_LLM 등)을
#   서브로 라우팅할 때 사용된다. 지금은 풀에 등록만 하고 DEFAULT/UTILITY 는 메인 유지.
# LLM_POOL='[
#     {"id":"gemma-4-26b","provider":"openai_compat","endpoint":"http://vllm:8000/v1","model":"gemma-4-26b-a4b-it"},
#     {"id":"gemma-4-26b-sub","provider":"openai_compat","endpoint":"http://192.168.100.11:8001/v1","model":"gemma-4-26b-a4b-it"},
#     {"id":"claude-haiku-4-5","provider":"bedrock","model":"global.anthropic.claude-haiku-4-5-20251001-v1:0","api_key_env":"AWS_BEARER_TOKEN_BEDROCK"},
#     {"id":"claude-opus-4-8","provider":"bedrock","model":"global.anthropic.claude-opus-4-8","api_key_env":"AWS_BEARER_TOKEN_BEDROCK"}
# ]'
LLM_POOL='[
    {"id":"gemma-4-26b","provider":"openai_compat","endpoint":"http://vllm:8000/v1","model":"gemma-4-26b-a4b-it"},
    {"id":"gemma-4-26b-sub","provider":"openai_compat","endpoint":"http://192.168.100.11:8001/v1","model":"gemma-4-26b-a4b-it"}
]'
DEFAULT_LLM=gemma-4-26b
UTILITY_LLM=gemma-4-26b
# worker 노드(서브, 2번째 DGX Spark) — relevance(retrieval.verify_slot)·multihop
# (retrieval.follow_up)을 *둘 다* 서브 vLLM 에서 돈다. main(gemma-4-26b)은 생성·앞단
# (N0/N1/N2) 전담 → 검색-검증 fan-out 이 생성 디코딩 큐와 경쟁하지 않아 검증↔생성이 물리
# 병렬(지연 단축). 빈 값이면 default_llm 폴백(단일노드). 서브 다운 시 `make up-onprem-sub`.
SECONDARY_LLM=gemma-4-26b-sub
SPEC_DRIVEN_V2_VERIFY_ENABLED=true
# 동시에 도는 슬롯 수 캡(러너 _verify_sem + tool). 최대 슬롯 수(≤10)에 맞춰 넉넉히 둔다 —
# 실제 Node1 보호는 청크별 전역 캡이 담당한다(SlotVerifierLlm 소유, 슬롯 fan-out 전체에
# 걸침). verify 는 청크마다 독립 LLM 호출을 asyncio.gather 로 동시 발사 → worker 노드
# (SECONDARY_LLM) vLLM 의 continuous batching 으로 묶인다. 이 캡은 별도 변수 없이
# SPEC_DRIVEN_MAX_QUERIES 를 재사용한다(profiles.py) — N2 슬롯×쿼리 규모와 같은 손잡이로 함께 키운다.
SPEC_DRIVEN_V2_VERIFY_CONCURRENCY=10
LLM_TIMEOUT_S=60
LLM_MAX_ATTEMPTS=2

# ── Retrieval — OpenSearch 3.6 단일 노드 (docker/opensearch 와 동일 설정) ──
RETRIEVER_BACKEND=opensearch
OPENSEARCH_ENDPOINT=http://opensearch:9200
OPENSEARCH_INDEX=nrc-all-v1
# hybrid 폴백 pipeline. RETRIEVER_TOP_K 가 벤치마크 operating point 면 자동
# 오버라이드된다: 10→nrc-hybrid-search-k10([0.4,0.2,0.4]). k=5(및 그 외)는 이 값을
# 사용 — k5 전용 pipeline 은 클러스터 미등록이라 맵에서 제외됨(profiles.py).
OPENSEARCH_SEARCH_PIPELINE=nrc-hybrid-search
OPENSEARCH_DENSE_FIELD=dense_e5
OPENSEARCH_SPARSE_FIELD=sparse_fermi
OPENSEARCH_TEXT_FIELD=text
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=false
RETRIEVER_K_DENSE=50

# Embedding (호스트 Python이 사전 인코딩하지만, backend 부팅 시 로드되는 모델 경로)
# 온프레미스는 호스트 ./models 의 평면 디렉토리를 그대로 사용한다.
# compose.onprem.yml 이 ../../models 를 /app/models 로 ro 마운트하므로
# 라이브러리는 절대 경로를 모델 디렉토리로 직접 인식한다(HF 캐시 레이아웃 불필요).
EMBEDDING_E5_MODEL=/app/models/intfloat/multilingual-e5-large
EMBEDDING_FERMI_MODEL=/app/models/atomic-canyon/fermi-1024
EMBEDDING_DEVICE=cpu
EMBEDDING_E5_MAX_SEQ_LEN=512
EMBEDDING_FERMI_MAX_SEQ_LEN=1024
EMBEDDING_FERMI_TOP_N=200

# State DB / Memory
STATE_DB_URL=postgresql://agent:agent@postgres:5432/agent_state
MEMORY_ENABLED=true
MEMORY_STORE=postgres
MEMORY_VECTOR_BACKEND=pgvector
MEMORY_REVIEW_REQUIRED=true
MEMORY_APPROVED_ONLY=true
MEMORY_SESSION_TTL_DAYS=90
MEMORY_STALENESS_CHECK_ENABLED=true

# Artifact / event sink — onprem 은 MinIO
EVENT_SINK=minio
EVENT_BUCKET=smr-agent-events
EVENT_PREFIX=onprem
EVENT_FILESYSTEM_ROOT=/var/lib/agent/events
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Capture modes — 온프레미스는 외부 유출이 없으므로 full snapshot 허용
TRACE_CONTENT_MODE=full
CONTEXT_CAPTURE_MODE=full

# Compose
BACKEND_TAG=onprem

# OpenWebUI
OPEN_WEBUI_VERSION=main
OPEN_WEBUI_PORT=3100
OPEN_WEBUI_AUTH=true
OPEN_WEBUI_NAME=SMR Agent (On-Prem)
OPEN_WEBUI_SECRET_KEY=change-me-onprem
OPEN_WEBUI_AGENT_KEY=dummy
# 모델 시드 — 새 채팅 기본 선택 페르소나(`<variant>@<llm>` 전체값). onprem llm id=gemma-4-26b
# (LLM_POOL). 설계자를 기본으로(메인 유스케이스). 다른 페르소나는 드롭다운에서 선택.
OPEN_WEBUI_DEFAULT_MODELS=composer_pipelined_designer@gemma-4-26b
# 모델 메타데이터(JSON) — 페르소나 역할 설명을 모델 카드에 시드. 표시명 자체는 v0.9.5 env
# 경로가 없어 Workspace>Models 에서 보강(이 description 은 거기 함께 노출됨). 키=모델 id.
OPEN_WEBUI_MODEL_METADATA={"composer_pipelined_reviewer@gemma-4-26b":{"description":"심사자 — 설계가 규제 요건을 충족하는지 평가(요건→기준→심사판단)"},"composer_pipelined_designer@gemma-4-26b":{"description":"설계자 — NuScale이 FSAR에서 어떻게 설계·인허가했는지(설계 주장+RAI/SER 심사 dialogue)"},"composer_pipelined_operator@gemma-4-26b":{"description":"운영자 — 인허가된 플랜트 운전·준수 요건(적용조건→ITAAC/운전제한→근거)"}}

# follow-up 참조 추출 (통합 메타데이터)
DOCUMENTS_METADATA_CSV=/app/data/ref/metadata_unified.csv
DOCUMENTS_METADATA_CACHE=/app/data/ref/_ref_catalog.json
# 청크별 vLLM 추출 동시성 캡 — 슬롯 fan-out 전체에 걸친 전역값. 청크별 독립 HTTP 요청을
# 동시에 쏴 서브 vLLM(SECONDARY_LLM=gemma-4-26b-sub)의 continuous batching 으로 묶어 처리한다.
# 이 vLLM 은 VLLM_MAX_NUM_SEQS=64 라 동시 64 시퀀스까지 배치 가능 — 캡 8 은 그 여유 안에서
# 8청크를 1라운드(ceil(8/8)=1 × per-call 30s ≈ 30s < registry 100s)에 처리한다. 단,
# follow_up 은 서브 노드를 단독으로 쓰지만(검증은 swap 후 메인 노드 별개), 캡을 너무 높여
# in-flight 가 폭주하면 KV cache 경쟁으로 청크당 디코딩이 느려져 per-call 타임아웃
# 캐스케이드가 날 수 있다(과거 무제한 발사 실측 91s/8청크). 경쟁이 보이면 낮춘다.
DOCUMENTS_REF_MAX_CONCURRENCY=8
DOCUMENTS_REF_VLLM_TIMEOUT_S=30

# vLLM — cyankiwi/gemma-4-26B-A4B-it-AWQ-4bit (compressed-tensors, 4bit) 서빙.
# ./models/gemma4-awq 적재. served-model-name 은 비양자화와 동일 → LLM_POOL 불변.
# 컨텍스트는 모델 상한(max_position_embeddings=131072, 128K)까지 상향.
# ⚠ KV cache 부족 시 vLLM 이 가능한 최대치를 에러로 알려준다 → 아래 두 값을 그
#   값으로 낮춰 재기동(필요 시 VLLM_GPU_MEMORY_UTILIZATION 상향).
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_MODEL_DIR=/workspace/models/gemma4-awq
VLLM_SERVED_MODEL_NAME=gemma-4-26b-a4b-it
VLLM_MAX_MODEL_LEN=131072
# 동시성/배칭 (test 메인 노드 .env.main 기준).
VLLM_MAX_NUM_SEQS=64
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_GPU_MEMORY_UTILIZATION=0.70
VLLM_KV_CACHE_DTYPE=fp8

# Phoenix Prompt Playground → 내부망 vLLM 직결 (onprem 전용).
# compose.onprem.yml 의 phoenix: 오버라이드가 이 값을 OPENAI_BASE_URL/_API_KEY 로 주입한다.
# 컨테이너 간 통신이므로 vllm:8000(컨테이너 DNS)을 쓴다. 서브 노드 vLLM 으로 보내려면
# PHOENIX_OPENAI_BASE_URL 를 LAN IP:8001(예: http://10.0.0.x:8001/v1)로 바꾼다.
# vLLM 은 인증이 없어 키는 placeholder 면 충분. Playground model 필드엔
# VLLM_SERVED_MODEL_NAME(gemma-4-26b-a4b-it) 와 동일한 이름을 입력한다.
PHOENIX_OPENAI_BASE_URL=http://vllm:8000/v1
PHOENIX_OPENAI_API_KEY=dummy