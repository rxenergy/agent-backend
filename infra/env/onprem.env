# On-premise profile (v2) — air-gapped VM/bare metal.
# 외부 네트워크 없음. LLM은 호스트 GPU의 vLLM(gemma-4-26b-a4b-it) 단일.
APP_PROFILE=onprem
ENVIRONMENT=production
LOG_LEVEL=INFO

# Agent variant. 기본 agentic_finder_v4 — N0 번역·N2 답변사양·N3 Finder 루프는 모두
# 내부망 utility LLM(vLLM, openai_compat → generate_with_tools)을 사용한다. v3.1
# hierarchical_corrective 의 claim 분해·함의 검증도 동일 내부 LLM — onprem air-gapped
# 정책과 호환(외부 SaaS 미사용).
AGENT_VARIANTS_ENABLED=["agentic_finder_v4", "hierarchical_corrective_v3_1", "react_minimal_v1", "spec_driven_v1"]
DEFAULT_VARIANT=spec_driven_v1

# OpenTelemetry → collector → Phoenix + Tempo
OTEL_ENABLED=true
OTEL_SERVICE_NAME=smr-agent-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=http://phoenix:6006

# Prompt / tool registries (mounted into image)
PROMPT_SOURCE=local
PROMPT_LABEL=mvp
PROMPT_LOCAL_DIR=/app/prompts

TOOL_REGISTRY_PATH=/app/tools/registry.yaml
TOOL_TRACE_ENABLED=true
TOOL_TIMEOUT_DEFAULT_MS=3000
TOOL_RETRY_DEFAULT=0

# Classifier / verification
CLASSIFIER_BACKEND=llm
CLASSIFICATION_THRESHOLD=0.35
CLASSIFIER_ESCALATE_BELOW=0.35

VERIFICATION_CITATION_THRESHOLD=0.9
VERIFICATION_FAITHFULNESS_THRESHOLD=0.80
VERIFICATION_RETRY_ON_FAIL=true

CLAIM_VERIFICATION_ENABLED=false

# operating point. k=5 → base pipeline(OPENSEARCH_SEARCH_PIPELINE=nrc-hybrid-search)
# 사용. k5 전용 가중치 pipeline 은 클러스터 미등록이라 맵에서 제외됨(profiles.py).
RETRIEVER_TOP_K=5

ACTIVE_CELLS_MODE=all

MULTI_TURN_SUMMARY_ENABLED=true
MULTI_TURN_KEEP_TURNS=5

# LLM pool — onprem은 vLLM 단일. fake-echo 는 항상 자동 포함.
# docker/vllm/docker-compose.yml 의 served-model-name 과 일치해야 한다.
LLM_POOL='[
    {"id":"gemma-4-26b","provider":"openai_compat","endpoint":"http://vllm:8000/v1","model":"gemma-4-26b-a4b-it"},
    {"id":"claude-haiku-4-5","provider":"anthropic","endpoint":"https://api.anthropic.com/v1","model":"claude-haiku-4-5","api_key_env":"ANTHROPIC_API_KEY"},
    {"id":"claude-sonnet-4-6","provider":"anthropic","endpoint":"https://api.anthropic.com/v1","model":"claude-sonnet-4-6","api_key_env":"ANTHROPIC_API_KEY"},
    {"id":"claude-opus-4-8","provider":"anthropic","endpoint":"https://api.anthropic.com/v1","model":"claude-opus-4-8","api_key_env":"ANTHROPIC_API_KEY"}
]'
DEFAULT_LLM=gemma-4-26b
UTILITY_LLM=gemma-4-26b
LLM_TIMEOUT_S=60
LLM_MAX_ATTEMPTS=2

# ── Retrieval — OpenSearch 3.6 단일 노드 (docker/opensearch 와 동일 설정) ──
RETRIEVER_BACKEND=opensearch
OPENSEARCH_ENDPOINT=http://opensearch:9200
OPENSEARCH_INDEX=nrc-all-v1
# hybrid 폴백 pipeline. RETRIEVER_TOP_K 가 벤치마크 operating point 면 자동
# 오버라이드된다: 10→nrc-hybrid-search-k10([0.4,0.2,0.4]). k=5(및 그 외)는 이 값을
# 사용 — k5 전용 pipeline 은 클러스터 미등록이라 맵에서 제외됨(profiles.py).
OPENSEARCH_SEARCH_PIPELINE=nrc-hybrid-search
OPENSEARCH_DENSE_FIELD=dense_e5
OPENSEARCH_SPARSE_FIELD=sparse_fermi
OPENSEARCH_TEXT_FIELD=text
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=false
RETRIEVER_K_DENSE=50

# Embedding (호스트 Python이 사전 인코딩하지만, backend 부팅 시 로드되는 모델 경로)
# 온프레미스는 호스트 ./models 의 평면 디렉토리를 그대로 사용한다.
# compose.onprem.yml 이 ../../models 를 /app/models 로 ro 마운트하므로
# 라이브러리는 절대 경로를 모델 디렉토리로 직접 인식한다(HF 캐시 레이아웃 불필요).
EMBEDDING_E5_MODEL=/app/models/intfloat/multilingual-e5-large
EMBEDDING_FERMI_MODEL=/app/models/atomic-canyon/fermi-1024
EMBEDDING_DEVICE=cpu
EMBEDDING_E5_MAX_SEQ_LEN=512
EMBEDDING_FERMI_MAX_SEQ_LEN=1024
EMBEDDING_FERMI_TOP_N=200

# State DB / Memory
STATE_DB_URL=postgresql://agent:agent@postgres:5432/agent_state
MEMORY_ENABLED=true
MEMORY_STORE=postgres
MEMORY_VECTOR_BACKEND=pgvector
MEMORY_REVIEW_REQUIRED=true
MEMORY_APPROVED_ONLY=true
MEMORY_SESSION_TTL_DAYS=90
MEMORY_STALENESS_CHECK_ENABLED=true

# Artifact / event sink — onprem 은 MinIO
EVENT_SINK=minio
EVENT_BUCKET=smr-agent-events
EVENT_PREFIX=onprem
EVENT_FILESYSTEM_ROOT=/var/lib/agent/events
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Capture modes — 온프레미스는 외부 유출이 없으므로 full snapshot 허용
TRACE_CONTENT_MODE=full
CONTEXT_CAPTURE_MODE=full

# Compose
BACKEND_TAG=onprem

# OpenWebUI
OPEN_WEBUI_VERSION=main
OPEN_WEBUI_PORT=3100
OPEN_WEBUI_AUTH=true
OPEN_WEBUI_NAME=SMR Agent (On-Prem)
OPEN_WEBUI_SECRET_KEY=change-me-onprem
OPEN_WEBUI_AGENT_KEY=dummy

# vLLM (docker/vllm/docker-compose.yml 의 파라미터와 일치)
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_MODEL_DIR=/workspace/models/gemma4
VLLM_SERVED_MODEL_NAME=gemma-4-26b-a4b-it
VLLM_MAX_MODEL_LEN=16384
VLLM_MAX_NUM_BATCHED_TOKENS=4096
VLLM_GPU_MEMORY_UTILIZATION=0.70
VLLM_KV_CACHE_DTYPE=fp8