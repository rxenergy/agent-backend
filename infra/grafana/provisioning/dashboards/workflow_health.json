{
  "uid": "agent-workflow-health",
  "title": "Agent — Workflow Health",
  "tags": ["agent", "hierarchical_corrective", "plan-w2"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "안내",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "16-node Hierarchical Corrective 워크플로우 집계 건강도. 메트릭은 OTLP→Collector(:8889)→Prometheus(경로 B). **패널이 비어 있으면** Prometheus `/api/v1/label/__name__/values` 로 실제 메트릭명을 확인하세요(OTLP→Prometheus 변환이 `_total`/unit 접미사를 붙일 수 있음). latency 패널의 exemplar 점(trace_id)을 클릭하면 Tempo trace 로 점프합니다."
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "터미널 결과율 (answer / partial / refused)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "stacking": { "mode": "normal" } } } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (outcome) (rate(agent_requests_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "거부 사유별 (refusals by reason)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (reason) (rate(agent_refusals_total[5m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "검증 상태 분포 (Q3 — verification status)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "stacking": { "mode": "normal" } } } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (status) (rate(agent_verification_status_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "복구 후 게이트 결과 (Q1 — WEAK→PASS flip) + 모순율",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (outcome) (rate(agent_recover_outcome_total[5m]))",
          "legendFormat": "recover→{{outcome}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(agent_contradicted_total[5m])",
          "legendFormat": "contradicted"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Faithfulness 분위수 (judge-dependent — gate 화 금지 §10)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1 } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(agent_faithfulness_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.1, sum by (le) (rate(agent_faithfulness_bucket[5m])))",
          "legendFormat": "p10"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "요청 지연 p95/p50 (ms) — exemplar→trace",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_request_latency_bucket[5m])))",
          "legendFormat": "p95",
          "exemplar": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(agent_request_latency_bucket[5m])))",
          "legendFormat": "p50",
          "exemplar": true
        }
      ]
    }
  ]
}
